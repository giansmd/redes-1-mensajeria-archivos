<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>winProyComunicacion</RootNamespace>
    <AssemblyName>winProyComunicacionCOM1</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\Form1.cs" Link="Form1.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="..\Shared\Form1.Designer.cs" Link="Form1.Designer.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="..\Shared\Program.cs" Link="Program.cs" />
    <Compile Include="..\Shared\classComunicacion.cs" Link="classComunicacion.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\Shared\Form1.resx" Link="Form1.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Form1.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>
